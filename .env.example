# --- Polygon mainnet only (chain id 137) ---
NEXT_PUBLIC_DEFAULT_CHAIN_ID=137

# Deployed SidebetEscrow (legacy v1) on Polygon — verify with `npm run hh:verify`
NEXT_PUBLIC_ESCROW_ADDRESS_POLYGON=

# Deployed SidebetEscrowV2 — set after `npm run hh:deploy` or copy from deploy output.
# Sidebets use this on-chain escrow; prediction markets are fully off-chain
# (custodial engine + ledger) and need no market contracts.
NEXT_PUBLIC_ESCROW_V2_ADDRESS_POLYGON=

# Platform default settler (@admin) — seeded at 2% on new bets/markets
NEXT_PUBLIC_DEFAULT_SETTLER=0x445525f628D4840e2F14148f2547e6F270Caa3eb

# Optional custom Polygon RPC
NEXT_PUBLIC_POLYGON_RPC=

# --- Privy (auth + managed wallets) ---
# Create an app at https://dashboard.privy.io and paste the App ID + Secret.
# Enable login methods: Email, SMS, Google, and external wallets.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional — only if you set a client ID in the Privy dashboard
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASS@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Vercel Blob (profile avatars) ---
BLOB_STORE_ID="store_xxxxxxxx"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Hardhat deploy (local only — NEVER on Vercel) ---
# EVM private key for the wallet that deploys the contract; fund with POL for gas.
DEPLOYER_PRIVATE_KEY=
# Required for `npm run hh:verify` (post-deploy Polygonscan verification).
# Use a unified key from https://etherscan.io/apidashboard (works for Polygon via API v2).
POLYGONSCAN_API_KEY=
# Optional override for V2 verify constructor arg (defaults to NEXT_PUBLIC_DEFAULT_SETTLER).
# Only needed for deployments after the platform-fee update; older deployments use scripts/legacy/SidebetEscrowV2.sol automatically.
# VERIFY_V2_PLATFORM_FEE_RECIPIENT=
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# --- Custodial matching engine (Render service) ---
# Where the Next.js app reaches the engine's internal RPC (server-side only).
ENGINE_URL=http://localhost:8090
# Public WebSocket the browser connects to for live book + trade tape.
NEXT_PUBLIC_ENGINE_WS_URL=ws://localhost:8090/ws
# Shared secret authenticating Next -> engine RPC. Generate a long random string.
ENGINE_RPC_SECRET=
# Port the engine HTTP/WS server listens on.
ENGINE_PORT=8090

# --- Redis / Valkey (live orderbook hot store + pub/sub) ---
# e.g. Render Key Value internal URL, or redis://localhost:6379 for local dev.
REDIS_URL=redis://localhost:6379

# --- On-chain deposit/withdraw bridge ---
# Treasury wallet that receives USDC.e deposits and sends withdrawals.
# Server-only hot key — NEVER expose to the client or commit. Fund with POL for gas.
TREASURY_PRIVATE_KEY=
NEXT_PUBLIC_TREASURY_ADDRESS=
# Withdrawals at or above this many micro-USDC (6 decimals) are held for manual
# review instead of auto-sent. 0 disables auto-send entirely.
WITHDRAWAL_AUTO_LIMIT=500000000
