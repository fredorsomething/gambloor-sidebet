# --- Chain config ---
# Polygon mainnet (137) or Polygon Amoy testnet (80002)
NEXT_PUBLIC_DEFAULT_CHAIN_ID=80002

# Deployed SidebetEscrow address per chain (fill in after `npm run hh:deploy:amoy` / :polygon)
NEXT_PUBLIC_ESCROW_ADDRESS_POLYGON=
NEXT_PUBLIC_ESCROW_ADDRESS_AMOY=

# WalletConnect Cloud project ID (https://cloud.reown.com)
NEXT_PUBLIC_WC_PROJECT_ID=

# Optional custom RPC endpoints
NEXT_PUBLIC_POLYGON_RPC=
NEXT_PUBLIC_AMOY_RPC=

# --- Database (Neon Postgres) ---
# Pooled — use for Next.js / Prisma Client (Vercel + local dev)
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Unpooled — use for `prisma db push` / migrations (direct connection)
DATABASE_URL_UNPOOLED="postgresql://USER:PASS@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Hardhat (server-only; never expose) ---
# Wallet must hold POL on Polygon/Amoy for deploy gas (native token rebranded from MATIC).
DEPLOYER_PRIVATE_KEY=
POLYGONSCAN_API_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
