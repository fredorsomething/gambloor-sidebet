// Prisma schema for the off-chain metadata index.
// The escrow contract is the on-chain source of truth for funds + status; this
// database only stores human-readable bet content (title, description, terms)
// and a denormalized snapshot to make listing/search fast.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  // Wallet address is the identity. Stored checksummed. With Privy this is the
  // embedded or external EVM wallet linked to the authenticated Privy account.
  address String @id

  // Privy account linkage (a Privy user can link multiple wallets; we key the
  // profile by the active wallet address but record who owns it).
  privyId String? @unique
  email   String?

  username  String? @unique
  avatarUrl String?
  bio       String?
  twitter   String?
  discord   String?

  // Staff / trusted traders — shows verified.png after their display name.
  verified Boolean @default(false)

  // Profile badge chips (Admin is derived from wallet, not stored here).
  badges String[] @default(["User"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([privyId])
}

// Past usernames a wallet has used. Lets old `/u/<oldname>` links keep resolving
// to the same wallet after a rename, so a user's identity/stats stay reachable
// no matter how often they change their display name. Current usernames on the
// `User` row always take priority over history when resolving a handle.
model UsernameHistory {
  id        Int      @id @default(autoincrement())
  address   String // checksummed wallet that used this username
  username  String // lowercased former username
  createdAt DateTime @default(now())

  @@unique([username, address])
  @@index([username])
  @@index([address])
}

// A counter-offer on an Open sidebet. A would-be taker who likes the premise but
// wants different stakes/odds (or tweaked terms) sends revised terms to the
// proposer, who can accept, decline, or ignore. Purely off-chain negotiation:
// because the on-chain bet's stakes/terms are fixed at creation, an accepted
// offer is realized by the proposer relaunching the bet with the agreed terms.
model BetNegotiation {
  id          Int     @id @default(autoincrement())
  betId       Int
  fromAddress String // lowercased sender of this offer (proposer or would-be acceptor)
  toAddress   String? // lowercased recipient (legacy rows default to proposer in API)

  // Proposed stakes (wei-unit decimal strings) from the PROPOSER's perspective,
  // mirroring how a Bet stores them. The would-be acceptor stakes `acceptorStake`.
  proposerStake String
  acceptorStake String

  terms   String? // optional revised resolution terms
  message String? // optional note to the other party

  status String @default("Pending") // Pending | Accepted | Declined | Withdrawn

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bet            Bet             @relation(fields: [betId], references: [id], onDelete: Cascade)
  lockedOnBet    Bet?            @relation("LockedNegotiation")
  directMessages DirectMessage[]

  @@index([betId, status])
  @@index([fromAddress])
  @@index([toAddress])
}

// Peer reputation: one vote per (voter -> target). value is +1 (rep) or -1
// (downvote). The net score is the sum of values for a target. Self-votes are
// rejected at the API layer.
model RepVote {
  voter     String
  target    String
  value     Int // +1 or -1
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([voter, target])
  @@index([target])
}

// Public profile comments / "wall". Anyone signed in can leave a comment on a
// user's profile; it persists for everyone to see. Authors can delete their own.
model ProfileComment {
  id        Int      @id @default(autoincrement())
  target    String // profile owner address (lowercase)
  author    String // commenter address (lowercase)
  body      String
  gifUrl    String? // optional attached GIF (e.g. Giphy/Tenor media url)
  parentId  Int? // reply target (another ProfileComment.id) for threaded replies
  createdAt DateTime @default(now())

  @@index([target, createdAt])
  @@index([author])
  @@index([parentId])
}

// On-chain badge purchases (e.g. Supporter). One credit per transfer log.
model BadgePurchase {
  id        Int      @id @default(autoincrement())
  address   String // buyer (lowercase)
  badge     String // e.g. Supporter
  txHash    String
  logIndex  Int
  amount    String // wei string
  token     String // token contract (lowercase)
  createdAt DateTime @default(now())

  @@unique([txHash, logIndex])
  @@index([address])
}

// Discussion comments attached to a sidebet or a market. `subjectType` selects
// the parent ("bet" | "market") and `subjectId` is that row's primary key.
// Anyone signed in can comment; authors can delete their own.
model ThreadComment {
  id          Int      @id @default(autoincrement())
  subjectType String // "bet" | "market"
  subjectId   Int
  author      String // commenter address (lowercase)
  body        String
  gifUrl      String? // optional attached GIF media url
  parentId    Int? // reply target (another ThreadComment.id)
  createdAt   DateTime @default(now())

  @@index([subjectType, subjectId, createdAt])
  @@index([author])
  @@index([parentId])
}

// Likes on comments. `scope` selects which comment table the `commentId` refers
// to ("thread" | "profile"). One like per (scope, commentId, liker).
model CommentLike {
  id        Int      @id @default(autoincrement())
  scope     String // "thread" | "profile"
  commentId Int
  liker     String // lowercased address
  createdAt DateTime @default(now())

  @@unique([scope, commentId, liker])
  @@index([scope, commentId])
}

// Profile view tracking. One row per (target, viewer) within a dedupe window;
// `viewer` is the lowercased wallet address, or an "anon:<id>" key for signed-out
// visitors. The profile view count is the number of distinct rows for a target.
model ProfileView {
  id        Int      @id @default(autoincrement())
  target    String // lowercased address being viewed
  viewer    String // lowercased viewer address, or "anon:<id>"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([target, viewer])
  @@index([target])
}

// In-app notifications. One row per (recipient, event). `recipient` is the
// lowercase wallet address the notification is for. Created server-side when
// something relevant happens (comment, resolution, settlement, deposit, etc).
model Notification {
  id        Int      @id @default(autoincrement())
  recipient String // lowercase address
  type      String // comment | reply | resolution_proposed | resolution_verified | resolution_rejected | market_approved | market_rejected | bet_settled | market_resolved | deposit | withdrawal | status
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([recipient, read])
  @@index([recipient, createdAt])
}

// A user-submitted proposed resolution for a sidebet or market, sent to an
// admin/verifier for review before the outcome is finalized on-chain.
model ResolutionProposal {
  id              Int      @id @default(autoincrement())
  subjectType     String // "bet" | "market"
  subjectId       Int
  proposedBy      String // lowercase address
  proposedOutcome Int // winning outcome index the proposer claims
  note            String?
  status          String   @default("Pending") // Pending | Approved | Rejected
  reviewedBy      String? // lowercase admin address
  reviewNote      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([subjectType, subjectId])
}

// A user request to add an additional resolver/settler to a bet or market, sent
// to admins for review. The on-chain settler is fixed at creation, so an
// approved request lets a neutral admin/verifier act as an extra resolver.
model ResolverRequest {
  id          Int      @id @default(autoincrement())
  subjectType String // "bet" | "market"
  subjectId   Int
  requestedBy String // lowercase address of the requester
  suggested   String? // suggested resolver address (lowercase)
  reason      String?
  status      String   @default("Pending") // Pending | Approved | Rejected
  reviewedBy  String? // lowercase admin address (legacy admin review)
  approvedBy  String? // lowercase counterparty who approved
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subjectType, subjectId])
  @@index([status, createdAt])
}

// Approved settlers: only these addresses can be chosen to resolve a Sidebet or
// Market. Each sets their own fee (basis points). Seeded with the default wallet.
model ApprovedSettler {
  address   String   @id
  username  String?
  feeBps    Int      @default(200) // 2%
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approved])
}

model Bet {
  id Int @id @default(autoincrement())

  // On-chain references
  chainId       Int
  escrowAddress String
  onchainId     String // uint256 from the escrow, stored as decimal string
  txHash        String?

  // Roles + token snapshot (kept in sync with chain on read)
  proposer      String
  acceptor      String?
  settler       String // on-chain settler (always @admin for auto-settle)
  customSettler String? // optional off-chain resolver chosen at creation
  token         String
  tokenSymbol String?
  decimals    Int     @default(6)

  // Asymmetric stakes (wei-units, decimal strings). `amount` kept as the
  // proposer-side stake for backwards compatibility / legacy reads.
  amount        String
  proposerStake String @default("0")
  acceptorStake String @default("0")

  // Outcomes: ordered labels (e.g. ["Yes","No"] or custom brackets) and the
  // outcome index each side is backing.
  outcomes        Json @default("[\"Yes\",\"No\"]")
  proposerOutcome Int  @default(0)
  acceptorOutcome Int  @default(1)

  // Off-chain content
  title       String
  description String
  imageUrl    String? // market cover (Vercel Blob); not part of on-chain termsHash
  terms       String
  termsHash   String // 0x-prefixed keccak256 hex
  nonce       String

  // Lifecycle
  status           String    @default("Open") // Open | Matched | Settled | Cancelled | Refunded
  winner           String?
  winningOutcome   Int?
  feeBps           Int       @default(0) // settler fee snapshot at creation
  acceptDeadline   BigInt?
  estimatedEndDate DateTime?

  // When a counter-offer is accepted, terms/stakes lock onto this bet row.
  // `escrowRevisionNeeded` stays true until the proposer publishes a fresh
  // on-chain offer (new onchainId) for the same indexed bet.
  lockedNegotiationId  Int?    @unique
  intendedAcceptor     String? // lowercased wallet that should take the bet
  escrowRevisionNeeded Boolean @default(false)

  // Hidden from homepage feed and public search; direct /bets/[id] links still work.
  hiddenFromFeed Boolean @default(false)

  // Global-chat feed dedupe: set atomically before posting matched/settled announcements.
  matchedFeedAt DateTime?
  settledFeedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lockedNegotiation BetNegotiation?  @relation("LockedNegotiation", fields: [lockedNegotiationId], references: [id], onDelete: SetNull)
  negotiations      BetNegotiation[]

  @@unique([chainId, escrowAddress, onchainId])
  @@index([chainId, status])
  @@index([proposer])
  @@index([acceptor])
  @@index([settler])
}

// ---------------- CLOB prediction markets ----------------

model Market {
  id Int @id @default(autoincrement())

  // On-chain references
  chainId         Int
  exchangeAddress String // CTFExchange address
  ctfAddress      String // ConditionalTokens address
  conditionId     String // bytes32 hex
  questionId      String // bytes32 hex (keccak of termsHash + nonce)
  txHash          String?

  // Roles + collateral
  creator       String
  settler         String
  customSettler   String? // optional counterparty-approved resolver after creation
  feeBps          Int     @default(200) // settler fee snapshot
  token       String
  tokenSymbol String?
  decimals    Int     @default(6)

  // Off-chain content
  title       String
  description String
  imageUrl    String?
  terms       String
  termsHash   String
  nonce       String

  // Lifecycle. New markets start "Pending" until an admin approves them.
  status           String    @default("Open") // Pending | Open | Resolved | Rejected
  winningOutcome   Int?
  estimatedEndDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outcomes MarketOutcome[]
  fills    Fill[]
  stats    OutcomeStat[]

  @@unique([chainId, exchangeAddress, conditionId])
  @@index([chainId, status])
  @@index([creator])
  @@index([settler])
}

model MarketOutcome {
  id         Int    @id @default(autoincrement())
  marketId   Int
  index      Int
  label      String
  positionId String // ERC-1155 token id, uint256 as decimal string

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([marketId, index])
  @@index([positionId])
}

// ---------------- Custodial off-chain exchange (ledger) ----------------
//
// The matching engine (single-writer service) owns the live order book in
// Redis/memory; Postgres is the durable, auditable financial source of truth.
// All amounts are integer micro-units (10^6) of the collateral (USDC.e, 6
// decimals). A whole share redeems for 1 collateral unit (1_000_000 micro).

// A balance bucket. `kind` selects the asset:
//   COLLATERAL  -> a user's spendable USDC.e balance (marketId/outcomeIndex null)
//   SHARE       -> a user's outcome-share balance for (marketId, outcomeIndex)
//   RESERVE     -> per-market collateral backing minted complete sets
//   FEE         -> the house fee account (collateral)
// `balance` is free; `locked` is reserved by resting orders / pending withdrawals.
model Account {
  id           Int    @id @default(autoincrement())
  // Deterministic uniqueness key: `${kind}|${owner}|${marketId}|${outcomeIndex}`.
  // (Nullable columns can't be used in a composite unique because NULLs are
  // distinct in Postgres, so we key on a precomputed string instead.)
  key          String @unique
  owner        String // lowercased wallet address, or "house" / "market:<id>"
  kind         String // COLLATERAL | SHARE | RESERVE | FEE
  marketId     Int?
  outcomeIndex Int?

  balance BigInt @default(0)
  locked  BigInt @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines LedgerLine[]

  @@index([owner])
  @@index([marketId])
  @@index([kind])
}

// Double-entry journal. One row per economic event; its `lines` record the
// signed balance/locked movements across accounts. Collateral lines (including
// RESERVE + FEE) net to zero per transaction; share lines net by mint/merge.
model LedgerTx {
  id        Int      @id @default(autoincrement())
  type      String // DEPOSIT | WITHDRAWAL | TRADE | FEE | SETTLEMENT | LOCK | UNLOCK | CANCEL
  refId     String? // external reference (fill id, deposit txHash, withdrawal id...)
  marketId  Int?
  createdAt DateTime @default(now())

  lines LedgerLine[]

  @@index([type])
  @@index([marketId])
  @@index([createdAt])
}

model LedgerLine {
  id           Int    @id @default(autoincrement())
  txId         Int
  accountId    Int
  balanceDelta BigInt @default(0)
  lockedDelta  BigInt @default(0)

  tx      LedgerTx @relation(fields: [txId], references: [id], onDelete: Cascade)
  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([txId])
  @@index([accountId])
}

// Durable trade history (one row per matched fill). Replaces the old `Trade`.
model Fill {
  id        Int    @id @default(autoincrement())
  marketId  Int
  matchType String // NORMAL | MINT | MERGE
  qty       BigInt // micro-shares matched
  price     BigInt // taker execution price (micro-USDC per share) on taker outcome

  taker        String // lowercased
  takerSide    String // BUY | SELL
  takerOutcome Int
  takerCost    BigInt // micro-USDC the taker paid (BUY) or received (SELL), pre-fee
  takerFee     BigInt @default(0)

  maker        String // lowercased
  makerOrderId String
  makerSide    String
  makerOutcome Int
  makerCost    BigInt

  createdAt DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
  @@index([taker])
  @@index([maker])
}

// Denormalized read model for fast market-list odds, kept in sync by the engine
// on every book change. Not the order book itself — just best bid/ask/last.
model OutcomeStat {
  id           Int      @id @default(autoincrement())
  marketId     Int
  outcomeIndex Int
  bestBid      BigInt?
  bestAsk      BigInt?
  lastPrice    BigInt?
  updatedAt    DateTime @updatedAt

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([marketId, outcomeIndex])
  @@index([marketId])
}

// On-chain USDC.e deposit credited to a user's collateral balance. Idempotent
// per (txHash, logIndex) so the indexer can re-scan safely.
model Deposit {
  id        Int      @id @default(autoincrement())
  address   String // lowercased credited wallet
  amount    BigInt // micro-USDC
  txHash    String
  logIndex  Int
  chainId   Int      @default(137)
  createdAt DateTime @default(now())

  @@unique([txHash, logIndex])
  @@index([address])
}

// A user withdrawal request. Collateral is debited (moved to `locked`) on
// request; the bridge worker sends USDC.e on-chain and records the tx.
model Withdrawal {
  id        Int      @id @default(autoincrement())
  address   String // lowercased destination wallet
  amount    BigInt // micro-USDC sent to the user (net of fee)
  fee       BigInt   @default(0)
  status    String   @default("Pending") // Pending | Review | Processing | Sent | Failed | Rejected
  txHash    String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([address])
  @@index([status])
}

// Private 1:1 direct messages between two wallets. `sender`/`recipient` are
// lowercased addresses. `pair` is the deterministic conversation key
// (`min(addr)|max(addr)`) so a thread is easy to query regardless of direction.
model DirectMessage {
  id            Int       @id @default(autoincrement())
  pair          String
  sender        String
  recipient     String
  body          String    @default("")
  gifUrl        String?
  negotiationId Int? // structured counter-offer card (body may be empty)
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  negotiation BetNegotiation? @relation(fields: [negotiationId], references: [id], onDelete: SetNull)

  @@index([pair, createdAt])
  @@index([recipient, readAt])
  @@index([sender, createdAt])
  @@index([negotiationId])
}

// Site-wide global chat. Anyone signed in can post (rate-limited); everyone can
// read. `author` is the lowercased wallet address. `gifUrl` is an optional GIF.
model ChatMessage {
  id        Int      @id @default(autoincrement())
  author    String // lowercased wallet address
  body      String   @default("")
  gifUrl    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([author, createdAt])
}

// Global chat mute — blocked from posting until mutedUntil (null = permanent).
model ChatMute {
  address    String    @id // lowercased wallet
  mutedUntil DateTime?
  reason     String?
  mutedBy    String // lowercased admin wallet
  createdAt  DateTime  @default(now())

  @@index([mutedUntil])
}

// Lightweight presence for the "users online" counter. One row per browser
// session key (`cid`), refreshed on each chat poll. Online = rows seen recently.
model Presence {
  cid      String   @id // client-generated session id
  address  String? // lowercased wallet if signed in
  lastSeen DateTime @updatedAt

  @@index([lastSeen])
}

// `blocker` blocked `blocked` from DMs (neither can message the other).
model DmBlock {
  id        Int      @id @default(autoincrement())
  blocker   String // lowercase wallet
  blocked   String // lowercase wallet
  createdAt DateTime @default(now())

  @@unique([blocker, blocked])
  @@index([blocker])
  @@index([blocked])
}

// Singleton platform flags (row id=1). Admins toggle without redeploy.
model PlatformSettings {
  id                  Int      @id @default(1)
  allowMarketCreation Boolean  @default(false)
  sidebetFeeBps       Int      @default(0) // platform fee on new sidebets (bps of pool)
  updatedAt           DateTime @updatedAt
  updatedBy           String?
}
